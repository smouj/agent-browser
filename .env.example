# AgentBrowser - Environment Configuration
# Copy this file to .env and fill in the values

# Database (SQLite - uses local file by default)
DATABASE_URL="file:./db/custom.db"

# Playwright browser cache path
PLAYWRIGHT_BROWSERS_PATH=""

# Server port (Next.js)
PORT=3000

# WebSocket service port
WS_PORT=3005

# Application URL (for CORS in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: Default viewport for new sessions
# DEFAULT_VIEWPORT_WIDTH=1280
# DEFAULT_VIEWPORT_HEIGHT=720

# Optional: Authentication secret (for future auth features)
# AUTH_SECRET=""
